# Application
APP_NAME=Image Rating Server
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8080

# CORS
FRONTEND_URL=http://localhost:8081
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./app.db
DATABASE_ECHO=false

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log

# Qwen3-VL defaults
QWEN3_VL_API_KEY=
QWEN3_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN3_VL_MODEL_NAME=qwen3-vl-plus
