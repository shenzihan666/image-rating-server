# Test Environment Configuration
APP_NAME=Image Rating Server Test
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=test

# Server
HOST=127.0.0.1
PORT=8080

# Security - Test only keys
SECRET_KEY=test-secret-key-for-testing-only-not-for-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=http://localhost:8081
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000,http://test

# Database - Use in-memory or test file database
DATABASE_URL=sqlite+aiosqlite:///./test_app.db
DATABASE_ECHO=false

# Logging
LOG_LEVEL=WARNING
LOG_FILE_PATH=logs/test.log

# Upload Settings
UPLOAD_DIR=test_uploads
UPLOAD_MAX_FILE_SIZE=52428800
UPLOAD_MAX_FILES_PER_REQUEST=10
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,bmp
